{
  "name": "react-weather-extension",
  "version": "1.0.0",
  "description": "A Chrome extension that provides real-time weather updates, forecasts, and weather-related notifications directly in your browser. Easily check current conditions and plan your day with accurate, up-to-date weather information.",
  "scripts": {
    "start": "webpack --watch --progress --config webpack.dev.js",
    "build": "webpack --progress --config webpack.prod.js",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "author": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.181",
    "@types/react": "^18.0.6",
    "@types/react-dom": "^18.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "clean-webpack-plugin": "^3.0.0",
    "copy-webpack-plugin": "^7.0.0",
    "css-loader": "^5.2.4",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "html-webpack-plugin": "^4.5.2",
    "prettier": "^3.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "style-loader": "^2.0.0",
    "terser-webpack-plugin": "^5.1.1",
    "ts-loader": "^8.1.0",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.34.0",
    "webpack-cli": "^4.6.0",
    "webpack-merge": "^5.7.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9"
  }
}
